# Copy to .env for local development
# On Railway, set these as environment variables in the service settings

# Provided automatically by Railway PostgreSQL plugin
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Generate a strong random secret: openssl rand -hex 32
SECRET_KEY=change-me-to-a-strong-random-secret

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
ENVIRONMENT=production

# Comma-separated list of allowed frontend origins
# Set to your Railway frontend URL, e.g.: https://vovinam-web.up.railway.app
ALLOWED_ORIGINS=https://your-frontend.up.railway.app
